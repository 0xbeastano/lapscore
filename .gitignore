# ── Dependencies ─────────────────────────────────────
node_modules/
client/node_modules/

# ── Build outputs (regenerated by npm run build) ─────
client/dist/
release/
dist/

# ── Runtime data (user-specific, not source code) ────
data/*.json
data/*.db
data/*.log
data/scans/
data/reports/
data/ai_sessions.json
data/power_log.json
data/score_history.json
data/settings.json
data/device.json
data/alerts.json

# Keep the folder structure in git:
!data/.gitkeep
!data/scans/.gitkeep
!data/reports/.gitkeep

# ── Electron build artifacts ─────────────────────────
*.AppImage
*.dmg
*.snap

# ── Logs & debug files ───────────────────────────────
*.log
build-log*.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment & secrets ────────────────────────────
.env
.env.local
.env.production

# ── OS generated files ───────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini

# ── Editor files ─────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── Temp & debug ─────────────────────────────────────
check.js
tmp-*.png
*.tmp
